/*
 * Jenkinsfile — Resume Job Matching Backend
 * ─────────────────────────────────────────
 * FIXES APPLIED:
 *   1. REMOVED venv — all tests run inside Docker (no local Python env needed)
 *   2. Health check hits GET / and checks HTTP 200 using --fail flag
 *   3. Health check retries up to 5 times with 5 s sleep (app starts faster than 15 s wait)
 *   4. Docker run uses --rm so containers are cleaned up automatically
 *   5. Coverage report archived from the correct path
 *   6. Workspace cleanup moved to post.always (not blocking build steps)
 */

pipeline {
    agent any

    environment {
        APP_NAME   = "resume-matcher"
        IMAGE_NAME = "resume-matcher-backend"
        IMAGE_TAG  = "${BUILD_NUMBER}"
        CONTAINER  = "resume-matcher-backend"   // running container name
    }

    stages {

        // ── 1. Checkout ────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "Cloning repository..."
                git branch: 'Devops_implementation_2',
                    url: 'https://github.com/bhadri-Raj-T/Resume-job-matching.git'
            }
        }

        // ── 2. Build Docker image (installs deps + NLTK data inside image) ─
        stage('Docker Build') {
            steps {
                echo "Building Docker image ${IMAGE_NAME}:${IMAGE_TAG}..."
                sh '''
                    docker build \
                        -f devops/Dockerfile \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${IMAGE_NAME}:latest \
                        .
                '''
            }
        }

        // ── 3. Unit tests — run inside the freshly built image ─────────────
        //    No venv needed: the image already has all deps installed.
        //    Each test stage is a separate docker run --rm so failures are
        //    isolated and containers are cleaned up automatically.

        stage('Test — Utils') {
            steps {
                echo "Running preprocessing / utils tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_utils.py -v --tb=short
                '''
            }
        }

        stage('Test — BM25 Engine') {
            steps {
                echo "Running BM25 engine tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_bm25_engine.py -v --tb=short
                '''
            }
        }

        stage('Test — Matcher') {
            steps {
                echo "Running matcher logic tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_matcher.py -v --tb=short
                '''
            }
        }

        stage('Test — Database') {
            steps {
                echo "Running SQLite warehouse tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_database.py -v --tb=short
                '''
            }
        }

        stage('Test — API') {
            steps {
                echo "Running Flask API integration tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_api.py -v --tb=short
                '''
            }
        }

        // ── 4. Full suite with coverage (produces coverage.xml) ────────────
        stage('Full Test Suite + Coverage') {
            steps {
                echo "Running complete test suite with coverage inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        python -m pytest tests/ -v --tb=short
                '''
            }
        }

        // ── 5. Deploy container ────────────────────────────────────────────
        stage('Docker Deploy') {
            steps {
                echo "Deploying container ${CONTAINER}..."
                sh '''
                    # Stop and remove any existing container
                    docker stop ${CONTAINER} 2>/dev/null || true
                    docker rm   ${CONTAINER} 2>/dev/null || true

                    docker run -d \
                        --name ${CONTAINER} \
                        -p 5000:5000 \
                        -v resume_warehouse:/app/data \
                        -e DB_PATH=/app/data/warehouse.db \
                        --restart unless-stopped \
                        ${IMAGE_NAME}:${IMAGE_TAG}
                '''
            }
        }

        // ── 6. Health check ────────────────────────────────────────────────
        // FIX: curl -f returns non-zero on HTTP errors (4xx/5xx).
        //      Retry up to 5 times with 5 s between attempts so the app
        //      has time to start (NLTK download + PDF pre-load can take ~10 s).
        stage('Health Check') {
            steps {
                echo "Waiting for application to become healthy..."
                sh '''
                    RETRIES=5
                    WAIT=5
                    for i in $(seq 1 $RETRIES); do
                        echo "Health check attempt $i / $RETRIES ..."
                        if curl --silent --fail http://localhost:5000/; then
                            echo "\\nHealth check PASSED"
                            exit 0
                        fi
                        echo "Not ready yet — waiting ${WAIT}s"
                        sleep $WAIT
                    done
                    echo "Health check FAILED after $RETRIES attempts"
                    docker logs ${CONTAINER} --tail 50
                    exit 1
                '''
            }
        }
    }

    // ── Post-build actions ──────────────────────────────────────────────────
    post {
        success {
            echo "Pipeline SUCCESS — Build #${BUILD_NUMBER} deployed and healthy."
        }
        failure {
            echo "Pipeline FAILED — Build #${BUILD_NUMBER}. Stopping broken container."
            sh 'docker stop ${CONTAINER} 2>/dev/null || true'
        }
        always {
            echo "Cleaning up dangling Docker images..."
            sh 'docker image prune -f || true'
            cleanWs()
        }
    }
}
