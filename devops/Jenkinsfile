/*
 * Jenkinsfile — Resume Job Matching Backend
 * ─────────────────────────────────────────
 * FIXES APPLIED:
 *   1. REMOVED venv — all tests run inside Docker (no local Python env needed)
 *   2. Health check hits GET / and checks HTTP 200 using --fail flag
 *   3. Health check retries up to 5 times with 5 s sleep (app starts faster than 15 s wait)
 *   4. Docker run uses --rm so containers are cleaned up automatically
 *   5. Coverage report archived from the correct path
 *   6. Workspace cleanup moved to post.always (not blocking build steps)
 */

pipeline {
    agent any

    environment {
        APP_NAME   = "resume-matcher"
        IMAGE_NAME = "resume-matcher-backend"
        IMAGE_TAG  = "${BUILD_NUMBER}"
        CONTAINER  = "resume-matcher-backend"   // running container name
    }

    stages {

        // ── 1. Checkout ────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "Cloning repository..."
                git branch: 'Devops_implementation_2',
                    url: 'https://github.com/bhadri-Raj-T/Resume-job-matching.git'
            }
        }

        // ── 2. Build Docker image (installs deps + NLTK data inside image) ─
        stage('Docker Build') {
            steps {
                echo "Building Docker image ${IMAGE_NAME}:${IMAGE_TAG}..."
                sh '''
                    docker build \
                        -f devops/Dockerfile \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${IMAGE_NAME}:latest \
                        .
                '''
            }
        }

        // ── 3. Unit tests — run inside the freshly built image ─────────────
        //    No venv needed: the image already has all deps installed.
        //    Each test stage is a separate docker run --rm so failures are
        //    isolated and containers are cleaned up automatically.

        stage('Test — Utils') {
            steps {
                echo "Running preprocessing / utils tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_utils.py -v --tb=short
                '''
            }
        }

        stage('Test — BM25 Engine') {
            steps {
                echo "Running BM25 engine tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_bm25_engine.py -v --tb=short
                '''
            }
        }

        stage('Test — Matcher') {
            steps {
                echo "Running matcher logic tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_matcher.py -v --tb=short
                '''
            }
        }

        stage('Test — Database') {
            steps {
                echo "Running SQLite warehouse tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_database.py -v --tb=short
                '''
            }
        }

        stage('Test — API') {
            steps {
                echo "Running Flask API integration tests inside Docker..."
                sh '''
                    docker run --rm \
                        -e DB_PATH=/tmp/test_warehouse.db \
                        --workdir /app \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        python -m pytest tests/test_api.py -v --tb=short
                '''
            }
        }

   
    }
}
