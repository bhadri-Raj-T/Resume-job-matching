pipeline {
    agent any

    environment {
        APP_NAME    = "resume-matcher"
        IMAGE_NAME  = "resume-matcher-backend"
        IMAGE_TAG   = "${BUILD_NUMBER}"
        PYTHONPATH  = "${WORKSPACE}"   // ✅ FIX: make root visible to Python
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Cloning repository..."
                git branch: 'main',
                    url: 'https://github.com/bhadri-Raj-T/Resume-job-matching.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "Installing Python dependencies..."
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install -r backend/requirements.txt
                    python -m nltk.downloader punkt punkt_tab stopwords
                '''
            }
        }

        stage('Run All Tests') {
            steps {
                echo "Running all tests..."
                sh '''
                    . venv/bin/activate
                    export PYTHONPATH=$(pwd)
                    echo "PYTHONPATH is: $PYTHONPATH"
                    cd backend
                    python -m pytest tests/ -v --tb=short
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'backend/coverage.xml', allowEmptyArchive: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building Docker image..."
                sh '''
                    docker build \
                        -f devops/Dockerfile \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${IMAGE_NAME}:latest \
                        .
                '''
            }
        }

        stage('Docker Deploy') {
            steps {
                echo "Deploying container..."
                sh '''
                    docker stop ${IMAGE_NAME} 2>/dev/null || true
                    docker rm   ${IMAGE_NAME} 2>/dev/null || true

                    docker run -d \
                        --name ${IMAGE_NAME} \
                        -p 5000:5000 \
                        -v resume_warehouse:/app/data \
                        -e DB_PATH=/app/data/warehouse.db \
                        --restart unless-stopped \
                        ${IMAGE_NAME}:${IMAGE_TAG}
                '''
            }
        }

        stage('Health Check') {
            steps {
                echo "Waiting for app to start..."
                sh '''
                    sleep 15
                    curl -f http://localhost:5000/ || (echo "Health check failed!" && exit 1)
                '''
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS — Build #${BUILD_NUMBER} deployed."
        }
        failure {
            echo "Pipeline FAILED — Check logs for Build #${BUILD_NUMBER}."
            sh 'docker stop ${IMAGE_NAME} 2>/dev/null || true'
        }
        always {
            echo "Cleaning up workspace..."
            sh 'rm -rf venv || true'
        }
    }
}
